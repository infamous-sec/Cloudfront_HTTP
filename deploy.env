# FTP/SFTP host (e.g. ftp.yourdomain.com or sftp://yourdomain.com)
FTP_HOST=ftp.example.com

# FTP username provided by your hosting provider
FTP_USER=your-ftp-username

# FTP password (leave blank for security; use secrets in CI or Portainer)
FTP_PASS=

# Remote path to deploy to on cPanel shared hosting
FTP_PATH=/public_html/
